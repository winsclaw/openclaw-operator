# Copy this file to deploy/.env before running install.sh
# You can also point install.sh to another file with:
# OPENCLAW_ENV_FILE=/path/to/your.env ./install.sh

OPENAI_API_KEY=sk-your-openai-compatible-api-key
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENCLAW_GATEWAY_TOKEN=replace-with-a-random-token
OPENCLAW_PRIMARY_MODEL=qwen3.5-plus

# Optional: override the operator image directly, or configure it by registry/repository/tag.
# OPENCLAW_OPERATOR_IMAGE=
IMAGE_REGISTRY=docker.io
IMAGE_PUSH_REGISTRY=docker.io
OPENCLAW_OPERATOR_IMAGE_REPOSITORY=openclaw/openclaw-operator
OPENCLAW_OPERATOR_IMAGE_TAG=latest

# Optional: override the OpenClaw application image used by each instance.
# Leave blank to use the operator built-in defaults.
OPENCLAW_IMAGE_REPOSITORY=
OPENCLAW_IMAGE_TAG=
OPENCLAW_IMAGE_PULL_POLICY=

# Optional: override the Chromium (headless browser) sidecar image.
# Leave blank to use the operator built-in defaults.
OPENCLAW_CHROMIUM_IMAGE_REPOSITORY=
OPENCLAW_CHROMIUM_IMAGE_TAG=
OPENCLAW_CHROMIUM_IMAGE_PULL_POLICY=

# Optional: set OPENCLAW_INGRESS_HOST to enable ingress automatically.
# OPENCLAW_INGRESS_ENABLED supports: auto, true, false.
OPENCLAW_INGRESS_ENABLED=auto
OPENCLAW_INGRESS_HOST=
OPENCLAW_INGRESS_CLASS_NAME=nginx
OPENCLAW_INGRESS_TLS_SECRET_NAME=openclaw-tls

# Optional: comma-separated ingress controller IPs. Leave empty to auto-discover.
OPENCLAW_TRUSTED_PROXIES=

# Optional: relax Control UI auth for local/non-secure browser contexts.
# This does not disable remote device pairing checks for Ingress access.
OPENCLAW_CONTROL_UI_ALLOW_INSECURE_AUTH=false

# Optional and dangerous: disable Control UI device identity checks entirely
# and rely on token/password only, including remote browser access.
OPENCLAW_CONTROL_UI_DANGEROUSLY_DISABLE_DEVICE_AUTH=false

# Optional: mount a custom CA bundle into the deployment.
OPENCLAW_CA_CERT_FILE=
OPENCLAW_CA_BUNDLE_CONFIGMAP_NAME=openclaw-ca-bundle
